      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "middle",
      "baseline": 11,
      "containerId": null,
      "originalText": "Green = user-facing path. Blue = app/backend. Yellow = external SendGrid/email systems. Gray = required setup before production.",
      "lineHeight": 1.25
    },
