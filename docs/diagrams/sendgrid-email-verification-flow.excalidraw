      "index": null,
      "roundness": null,
      "text": "Required before SendGrid can work",
      "fontSize": 19,
      "fontFamily": 1,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 15,
      "containerId": null,
      "originalText": "Required before SendGrid can work",
      "lineHeight": 1.25
    },
    {
      "id": "HG_kLGMdLdh9",
      "type": "text",
      "x": 84,
      "y": 163,
      "width": 1052,
      "height": 66,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "seed": 2781625152,
      "version": 1,
      "versionNonce": 203723653,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1780912552292,
      "link": null,
      "locked": false,
      "groupIds": [],
      "frameId": null,
      "index": null,
      "roundness": null,
      "text": "1. SendGrid account with an API key that has Mail Send permission.\n2. Verified Sender Identity: authenticated domain is best for production; single sender is acceptable for testing.\n3. Railway/backend env vars: SENDGRID_API_KEY, DEFAULT_FROM_EMAIL, FRONTEND_URL.\n4. DEFAULT_FROM_EMAIL must match a verified sender/domain.\n5. Backend can reach smtp.sendgrid.net:587 using STARTTLS; database and migrations are healthy.",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "center",
      "verticalAlign": "top",
      "baseline": 11,
      "containerId": null,
      "originalText": "1. SendGrid account with an API key that has Mail Send permission.\n2. Verified Sender Identity: authenticated domain is best for production; single sender is acceptable for testing.\n3. Railway/backend env vars: SENDGRID_API_KEY, DEFAULT_FROM_EMAIL, FRONTEND_URL.\n4. DEFAULT_FROM_EMAIL must match a verified sender/domain.\n5. Backend can reach smtp.sendgrid.net:587 using STARTTLS; database and migrations are healthy.",
      "lineHeight": 1.25
    },
